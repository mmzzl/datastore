{
  "name": "double_ma_strategy",
  "version": "1.0.1",
  "display_name": "双均线交叉策略",
  "description": "经典双均线交叉策略。当短期均线上穿长期均线时买入，下穿时卖出。适用于趋势行情。",
  "author": "system",
  "strategy_class": "DoubleMAStrategy",
  "min_data_points": 30,
  "tags": ["trend", "ma", "classic"],
  "parameters": {
    "fast_period": {
      "type": "integer",
      "default": 5,
      "label": "短期均线周期",
      "min": 2,
      "max": 30
    },
    "slow_period": {
      "type": "integer",
      "default": 20,
      "label": "长期均线周期",
      "min": 10,
      "max": 60
    },
    "ma_type": {
      "type": "enum",
      "default": "sma",
      "label": "均线类型",
      "options": ["sma", "ema"]
    }
  }
}
