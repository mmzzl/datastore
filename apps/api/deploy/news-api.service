[Unit]
Description=News API Service
After=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/home/fantom/datastore/case/apps/api
Environment="PATH=/usr/bin:/usr/local/bin"
Environment="PYTHONPATH=/home/fantom/datastore/case/apps/api"
ExecStart=/root/.pyenv/shims/python -m uvicorn main:app --host 0.0.0.0 --port 8000 --reload
Restart=always
RestartSec=5s
StandardOutput=syslog
StandardError=syslog
SyslogIdentifier=news-api

[Install]
WantedBy=multi-user.target
