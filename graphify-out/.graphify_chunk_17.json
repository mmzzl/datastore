      "id": "csi300_rebalance_concept",
      "type": "concept",
      "attributes": {
        "name": "CSI300 constituent rebalancing",
        "description": "Massive removal of stocks from csi300.txt indicating a major index constituent rebalance. Stocks removed include SH600000-SH600999 and SZ000001-SZ003816 ranges",
        "rationale": "The csi300 diff shows ~270 stocks removed and ~40 remaining, suggesting a quarterly or special rebalancing event. This is a significant structural change to the Qlib universe."
      }
    },
    {
      "id": "csi500_expansion_concept",
      "type": "concept",
      "attributes": {
        "name": "CSI500 constituent expansion",
        "description": "Massive addition of stocks to csi500.txt, growing from ~28 entries to ~596 entries. This aligns with stocks removed from CSI300 being redistributed to CSI500",
        "rationale": "The csi500 diff shows ~570 stocks added, the inverse of csi300 removals. This represents an index rebalancing event where former CSI300 constituents were moved to CSI500."
      }
    },
    {
      "id": "qlib_data_pipeline_concept",
      "type": "concept",
      "attributes": {
        "name": "Qlib data pipeline daily update",
        "description": "Daily update of Qlib binary data files including trading calendar extension and instrument universe maintenance for A-share quantitative trading",
        "rationale": "The calendar day.txt had 2026-04-29 appended, and instruments/all.txt had hundreds of new stock tickers added. These files feed into Qlib's data handler for model training."
      }
    },
    {
      "id": "npm_dependency_cleanup_concept",
      "type": "concept",
      "attributes": {
        "name": "NPM optional dependency cleanup",
        "description": "Removal of esbuild platform-specific optional packages (aix-ppc64, netbsd-arm64, openbsd-arm64, openharmony-arm64, and vitest/esbuild sub-dependencies) from package-lock.json",
        "rationale": "Cleaning up unnecessary platform-specific esbuild binaries reduces lockfile size and npm install time on the target Windows platform."
      }
